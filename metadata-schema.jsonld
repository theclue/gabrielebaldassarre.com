{
  "@context": "https://schema.org",
  "@type": "DefinedTermSet",
  "@id": "https://gabrielebaldassarre.com/metadata-schema.jsonld",
  "name": "gabrielebaldassarre.com — Custom Metadata Ontology",
  "description": "Schema dei metadati custom utilizzati nei JSON-LD del blog. Ogni proprietà è namespace-izzata per distinguere metriche lessicali (deterministiche, calcolate a build-time) da metriche cognitive (LLM-based, stimate in pipeline asincrona).",
  "hasDefinedTerm": [
    {
      "@type": "DefinedTerm",
      "termCode": "flesch_vacca",
      "name": "Flesch-Kincaid (Franchini-Vacca 1972)",
      "description": "Adattamento italiano dell'indice di leggibilità Flesch-Kincaid. Formula (versione 1972): F=206−(0.65×S)−P con S=sillabe/100 parole, P=parole medie per frase. La versione 1972 è indicata come più attendibile dal Gruppo Universitario Linguistico-Pedagogico (fonte: Wikipedia).",
      "citation": [
        {
          "@type": "CreativeWork",
          "author": [{"@type": "Person", "name": "Valerio Franchina"}, {"@type": "Person", "name": "Roberto Vacca"}],
          "name": "Adaptation of Flesh readability index on a bilingual text written by the same author both in Italian and English languages",
          "datePublished": "1986",
          "publication": {"@type": "PublicationIssue", "isPartOf": {"@type": "PublicationVolume", "name": "Linguaggi", "volumeNumber": 3}, "pageStart": "47", "pageEnd": "49"}
        },
        {
          "@type": "CreativeWork",
          "author": [{"@type": "Person", "name": "Valerio Franchina"}, {"@type": "Person", "name": "Roberto Vacca"}],
          "name": "Adattamento italiano della formula di Flesch per la leggibilità (versione 1972)",
          "datePublished": "1972",
          "description": "Versione originale del 1972, citata da Wikipedia come la più attendibile per la lingua italiana."
        }
      ],
      "inDefinedTermSet": { "@id": "https://gabrielebaldassarre.com/metadata-schema.jsonld" }
    },
    {
      "@type": "DefinedTerm",
      "termCode": "gulpease",
      "name": "GULPEASE Readability Index",
      "description": "Indice di leggibilità specifico per la lingua italiana. Formula: G=89−(LP/10)+(3×SP) dove LP=lettere/100 parole, SP=frasi/100 parole. Range 0–100, valori alti = testo più facile. Sviluppato dal GULP (Gruppo Universitario Linguistico-Pedagogico).",
      "inDefinedTermSet": { "@id": "https://gabrielebaldassarre.com/metadata-schema.jsonld" }
    },
    {
      "@type": "DefinedTerm",
      "termCode": "lexical_educational_level",
      "name": "Lexical Educational Level",
      "description": "Livello scolastico italiano stimato su base puramente lessicale (Flesch-Vacca 1972). NON riflette la complessità cognitiva del contenuto: un testo su meccanica quantistica scritto con frasi brevi può risultare 'scuola primaria' lessicalmente pur richiedendo competenze universitarie. Per la complessità cognitiva si usa il namespace 'cognitive_*' (pipeline LLM-based, calcolata asincronamente).",
      "inDefinedTermSet": { "@id": "https://gabrielebaldassarre.com/metadata-schema.jsonld" }
    },
    {
      "@type": "DefinedTerm",
      "termCode": "lexical_typical_age_range",
      "name": "Lexical Typical Age Range",
      "description": "Età tipica associata al lexical_educational_level. Mappatura: scuola primaria=6-11, secondaria I grado=11-14, secondaria II grado=14-19, università=19-24, post-laurea=24+.",
      "inDefinedTermSet": { "@id": "https://gabrielebaldassarre.com/metadata-schema.jsonld" }
    },
    {
      "@type": "DefinedTerm",
      "termCode": "word_count",
      "name": "Word Count",
      "description": "Numero di parole nel contenuto testuale del post (strip HTML e Markdown). Esposto come wordCount nativo schema.org/Article.",
      "inDefinedTermSet": { "@id": "https://gabrielebaldassarre.com/metadata-schema.jsonld" }
    },
    {
      "@type": "DefinedTerm",
      "termCode": "sentence_count",
      "name": "Sentence Count",
      "description": "Numero di frasi rilevate nel testo.",
      "inDefinedTermSet": { "@id": "https://gabrielebaldassarre.com/metadata-schema.jsonld" }
    },
    {
      "@type": "DefinedTerm",
      "termCode": "syllable_count",
      "name": "Syllable Count",
      "description": "Numero totale di sillabe rilevate con conteggio euristico su vocali italiane.",
      "inDefinedTermSet": { "@id": "https://gabrielebaldassarre.com/metadata-schema.jsonld" }
    },
    {
      "@type": "DefinedTerm",
      "termCode": "avg_sentence_length",
      "name": "Average Sentence Length",
      "description": "Lunghezza media delle frasi in parole (word_count / sentence_count).",
      "inDefinedTermSet": { "@id": "https://gabrielebaldassarre.com/metadata-schema.jsonld" }
    },
    {
      "@type": "DefinedTerm",
      "termCode": "image_role",
      "name": "Image Role",
      "description": "Natura intrinseca dell'asset visivo, indipendente dal contesto narrativo. Valori: decorative (alt=\"\", role=\"presentation\", no JSON-LD), screenshot (cattura schermata), diagram (schema architetturale, richiede long_description), chart (grafico quantitativo, richiede long_description), photo (fotografia reale), illustration (disegno concettuale), code (screenshot di codice).",
      "inDefinedTermSet": { "@id": "https://gabrielebaldassarre.com/metadata-schema.jsonld" }
    },
    {
      "@type": "DefinedTerm",
      "termCode": "image_context",
      "name": "Image Narrative Context",
      "description": "Funzione narrativa dell'immagine nel flusso dell'articolo, ortogonale al role. Valori: step (illustra uno step del tutorial, richiede step:N), result (mostra il risultato atteso), architecture (mostra struttura/design/topologia), comparison (confronto prima/dopo, richiede compare_with), reference (materiale di riferimento esterno), evidence (prova/dimostrazione), ambient (contesto visivo non puramente decorativo).",
      "inDefinedTermSet": { "@id": "https://gabrielebaldassarre.com/metadata-schema.jsonld" }
    },
    {
      "@type": "DefinedTerm",
      "termCode": "step",
      "name": "Step Number",
      "description": "Numero intero che identifica lo step del tutorial a cui l'immagine appartiene. Usato esclusivamente con image_context=step. Genera id=\"step-N-image\" e abilita il collegamento HowToStep nell'ImageObject JSON-LD.",
      "inDefinedTermSet": { "@id": "https://gabrielebaldassarre.com/metadata-schema.jsonld" }
    },
    {
      "@type": "DefinedTerm",
      "termCode": "compare_with",
      "name": "Compare With",
      "description": "Percorso dell'immagine con cui questa va confrontata (es. 'prima.png'). Usato esclusivamente con image_context=comparison. Genera data-compare-with nell'HTML e il collegamento nell'ImageObject JSON-LD. Non genera automaticamente layout side-by-side (solo annotazione semantica).",
      "inDefinedTermSet": { "@id": "https://gabrielebaldassarre.com/metadata-schema.jsonld" }
    },
    {
      "@type": "DefinedTerm",
      "termCode": "link_role",
      "name": "Link Role",
      "description": "Natura semantica del link. Valori: citation, source, definition, tool, prerequisite, deepening, related, self, demo, download, attribution, commercial. 12/12 ruoli hanno mapping nativo Schema.org su CreativeWork.",
      "inDefinedTermSet": { "@id": "https://gabrielebaldassarre.com/metadata-schema.jsonld" }
    },
    {
      "@type": "DefinedTerm",
      "termCode": "link_context",
      "name": "Link Narrative Context",
      "description": "Funzione narrativa del link nel flusso dell'articolo. Valori: supports-claim, provides-context, enables-step, validates-result, credits-author, offers-alternative, extends-topic. Concetto editoriale senza equivalente Schema.org diretto.",
      "inDefinedTermSet": { "@id": "https://gabrielebaldassarre.com/metadata-schema.jsonld" }
    },
    {
      "@type": "DefinedTerm",
      "termCode": "link_target",
      "name": "Link Target Classification",
      "description": "Classificazione della destinazione che guida gli attributi HTML rel e target. Valori: internal, external-authoritative (dofollow), external-community (ugc), external-commercial (sponsored), external-ugc. Link esterni generano automaticamente rel=\"noopener\" e target=\"_blank\" con icona MDI open-in-new.",
      "inDefinedTermSet": { "@id": "https://gabrielebaldassarre.com/metadata-schema.jsonld" }
    },
    {
      "@type": "DefinedTerm",
      "termCode": "source_type",
      "name": "Image Source Type",
      "description": "Tipo di sorgente dell'immagine. Valori: mermaid (diagramma generato da testo Mermaid, reso SVG a build-time), raster (immagine bitmap tradizionale). Quando source_type=mermaid, viene generato anche un SoftwareSourceCode JSON-LD con programmingLanguage: Mermaid e il testo sorgente.",
      "inDefinedTermSet": { "@id": "https://gabrielebaldassarre.com/metadata-schema.jsonld" }
    },
    {
      "@type": "DefinedTerm",
      "termCode": "diagram_type",
      "name": "Mermaid Diagram Type",
      "description": "Tipo di diagramma Mermaid. Valori: flowchart, sequence, class, state, er, gantt, pie, mindmap, gitgraph, journey, architecture. Determina il keyword Mermaid usato nel blocco di codice e guida le regole di accessibilità e rendering.",
      "inDefinedTermSet": { "@id": "https://gabrielebaldassarre.com/metadata-schema.jsonld" }
    },
    {
      "@type": "DefinedTerm",
      "termCode": "mermaid_direction",
      "name": "Mermaid Flowchart Direction",
      "description": "Direzione del flowchart Mermaid. Valori: TB (top→bottom), LR (left→right), RL (right→left), BT (bottom→top). Si applica solo a diagram_type=flowchart.",
      "inDefinedTermSet": { "@id": "https://gabrielebaldassarre.com/metadata-schema.jsonld" }
    },
    {
      "@type": "DefinedTerm",
      "termCode": "intended_audience",
      "name": "Intended Audience",
      "description": "Pubblico target dichiarato dall'autore. Valori: general (pubblico generico), curious (persone curiose con cultura generale), student (studenti con basi nel dominio), practitioner (professionisti che applicano), specialist (esperti del dominio specifico). Mappa su Schema.org audience.audienceType.",
      "inDefinedTermSet": { "@id": "https://gabrielebaldassarre.com/metadata-schema.jsonld" }
    },
    {
      "@type": "DefinedTerm",
      "termCode": "proficiency_level",
      "name": "Proficiency Level",
      "description": "Livello di competenza richiesto per comprendere l'articolo. Valori: beginner (nessuna esperienza pregressa), intermediate (conoscenze base), advanced (esperienza significativa), expert (specialista). Mappa su Schema.org proficiencyLevel (TechArticle) o educationalLevel (BlogPosting).",
      "inDefinedTermSet": { "@id": "https://gabrielebaldassarre.com/metadata-schema.jsonld" }
    },
    {
      "@type": "DefinedTerm",
      "termCode": "knowledge_prerequisites",
      "name": "Knowledge Prerequisites",
      "description": "Array di concetti/risorse che il lettore dovrebbe conoscere prima di leggere l'articolo. Ogni prerequisito ha: concept (identificativo), label (etichetta), url (link glossario), importance (required|recommended|helpful). I required mappano su Schema.org requires, i recommended su isBasedOn, gli helpful su relatedLink.",
      "inDefinedTermSet": { "@id": "https://gabrielebaldassarre.com/metadata-schema.jsonld" }
    },
    {
      "@type": "DefinedTerm",
      "termCode": "difficulty_declared",
      "name": "Declared Difficulty",
      "description": "Stima soggettiva della difficoltà su tre assi (1-5): conceptual (difficoltà dei concetti), technical (difficoltà tecnica), mathematical (livello matematico, 0=nessuno). Valore editoriale, non ha equivalente Schema.org diretto. Usato per calcolare il difficulty_composite insieme alle metriche lessicali e semantiche.",
      "inDefinedTermSet": { "@id": "https://gabrielebaldassarre.com/metadata-schema.jsonld" }
    },
    {
      "@type": "DefinedTerm",
      "termCode": "difficulty_composite",
      "name": "Composite Difficulty Index",
      "description": "Indice sintetico di difficoltà (0-5) calcolato a build time: 40% media difficulty_declared + 30% lessicale (Gulpease) + 30% semantico (concept_density, prerequisite_depth, definition_coverage). Se le componenti semantiche non sono disponibili, il composito è calcolato solo sulle disponibili. Label: Accessibile (≤2), Intermedio (≤3), Avanzato (≤4), Esperto (>4).",
      "inDefinedTermSet": { "@id": "https://gabrielebaldassarre.com/metadata-schema.jsonld" }
    },
    {
      "@type": "DefinedTerm",
      "termCode": "cognitive_educational_level",
      "name": "Cognitive Educational Level",
      "description": "[FUTURO — pipeline LLM-based] Livello scolastico stimato in base alla complessità cognitiva del contenuto (lessicografia specialistica, densità concettuale, carico cognitivo intrinseco). Popolato asincronamente da una pipeline secondaria che arricchisce il frontmatter. Quando presente, il native 'educationalLevel' schema.org rifletterà questo valore.",
      "inDefinedTermSet": { "@id": "https://gabrielebaldassarre.com/metadata-schema.jsonld" }
    },
    {
      "@type": "DefinedTerm",
      "termCode": "cognitive_load",
      "name": "Cognitive Load Index",
      "description": "[FUTURO — pipeline LLM-based] Indice sintetico di fatica cognitiva (0–100). Combina complessità lessicografica, densità concettuale e tasso di informazione. Valori alti = maggiore sforzo cognitivo richiesto.",
      "inDefinedTermSet": { "@id": "https://gabrielebaldassarre.com/metadata-schema.jsonld" }
    },
    {
      "@type": "DefinedTerm",
      "termCode": "intended_audience",
      "name": "Intended Audience",
      "description": "[FUTURO — pipeline LLM-based] Profilo del lettore ideale: 'general', 'enthusiast', 'practitioner', 'researcher', 'expert'.",
      "inDefinedTermSet": { "@id": "https://gabrielebaldassarre.com/metadata-schema.jsonld" }
    },
    {
      "@type": "DefinedTerm",
      "termCode": "intended_intent",
      "name": "Intended Intent",
      "description": "[FUTURO — pipeline LLM-based] Obiettivo comunicativo del post: 'inform', 'teach', 'persuade', 'entertain', 'inspire', 'document'.",
      "inDefinedTermSet": { "@id": "https://gabrielebaldassarre.com/metadata-schema.jsonld" }
    }
  ]
}
