{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Compila il sito",
      "type": "shell",
      "command": "make site",
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Avvia il server di sviluppo",
      "type": "shell",
      "command": "make dev",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "isBackground": false,
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "dedicated",
        "showReuseMessage": false,
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Pulisci il sito",
      "type": "shell",
      "command": "make clean",
      "presentation": {
        "echo": true,
        "reveal": "silent",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": false,
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Esegui knitr",
      "type": "shell",
      "command": "make knitr",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Nuovo post",
      "type": "shell",
      "command": "rake post title='${input:postTitle}' category='${input:postCategory}'${input:postSubtitle}",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": false,
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Nuova bozza",
      "type": "shell",
      "command": "rake draft title='${input:draftTitle}'",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": false,
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Converti immagine in Cloudinary",
      "type": "shell",
      "command": "ruby",
      "args": [
        "${workspaceFolder}/.vscode/clipboard-image-to-cloudinary.rb",
        "${file}"
      ],
      "presentation": {
        "echo": true,
        "reveal": "silent",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": false,
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Esegui knitr sull'Rmd corrente",
      "type": "shell",
      "command": "noglob rake",
      "args": ["knit['${relativeFile}']"],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": false,
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Esegui knitr su tutti gli Rmd",
      "type": "shell",
      "command": "rake",
      "args": ["knit_all"],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": false,
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Nuovo workbook Rmd",
      "type": "shell",
      "command": "noglob rake",
      "args": ["new_rmd['${input:rmdTitle}','${input:rmdCategory}']"],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": false,
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Nuovo asset 3D",
      "type": "shell",
      "command": "noglob rake",
      "args": ["new_3d['${input:cadTitle}','${input:cadSlug}']"],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": false,
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "CAD: compila singolo asset 3D",
      "type": "shell",
      "command": "make assets/3d/${input:cadSlug}/${input:cadSlug}.stl assets/3d/${input:cadSlug}/${input:cadSlug}.3mf",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": false,
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "CAD: compila asset corrente",
      "type": "shell",
      "command": "slug=$(dirname ${relativeFile} | xargs basename); make \"assets/3d/$slug/$slug.stl\" \"assets/3d/$slug/$slug.3mf\"",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": false,
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "CAD: compila tutto",
      "type": "shell",
      "command": "make cad",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": false,
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Configura sito",
      "type": "shell",
      "command": "./configure",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": false,
        "clear": true
      },
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "postTitle",
      "type": "promptString",
      "description": "Titolo del post",
      "default": ""
    },
    {
      "id": "postCategory",
      "type": "pickString",
      "description": "Categoria (sottodirectory in _posts/)",
      "options": [
        "Home Assistant",
        "DevOps",
        "Fisica",
        "Reti Sociali",
        "Meccanica",
        "3d Printing"
      ]
    },
    {
      "id": "postSubtitle",
      "type": "promptString",
      "description": "Sottotitolo (lascia vuoto per omettere)",
      "default": ""
    },
    {
      "id": "draftTitle",
      "type": "promptString",
      "description": "Titolo della bozza",
      "default": ""
    },
    {
      "id": "pubCategory",
      "type": "pickString",
      "description": "Categoria di destinazione",
      "options": [
        "Home Assistant",
        "DevOps",
        "Fisica",
        "Reti Sociali",
        "Meccanica",
        "3d Printing"
      ]
    },
    {
      "id": "rmdTitle",
      "type": "promptString",
      "description": "Titolo del post Rmd",
      "default": ""
    },
    {
      "id": "rmdCategory",
      "type": "pickString",
      "description": "Categoria",
      "options": [
        "Home Assistant",
        "DevOps",
        "Fisica",
        "Reti Sociali",
        "Meccanica",
        "3d Printing"
      ]
    },
    {
      "id": "rmdDraftTitle",
      "type": "promptString",
      "description": "Titolo della bozza Rmd",
      "default": ""
    },
    {
      "id": "cadTitle",
      "type": "promptString",
      "description": "Titolo del progetto 3D",
      "default": ""
    },
    {
      "id": "cadSlug",
      "type": "promptString",
      "description": "Slug (kebab-case, cartella sotto _cad/)",
      "default": ""
    }
  ]
}
