FROM python:3.12-slim

ENV PYTHONUNBUFFERED=1
ENV PIP_NO_CACHE_DIR=1

WORKDIR /workspace

# Install Python dependencies (dbt-sqlite is pure Python, no C compiler needed)
COPY requirements-seo.txt .
RUN pip install --no-cache-dir -r requirements-seo.txt

# Verify dbt is functional
RUN dbt --version

# Default entry point: run the SEO monitor
ENTRYPOINT ["python3", "_scripts/seo/monitor.py"]
