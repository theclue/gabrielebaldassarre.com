{
  "ci": {
    "collect": {
      "numberOfRuns": 1,
      "settings": {
        "chromeFlags": "--no-sandbox --headless --disable-gpu"
      }
    },
    "assert": {
      "preset": "lighthouse:no-pwa",
      "assertions": {
        "categories:performance": ["warn", {"minScore": 0.50}],
        "categories:accessibility": ["warn", {"minScore": 0.80}],
        "categories:seo": ["warn", {"minScore": 0.70}],
        "categories:best-practices": ["warn", {"minScore": 0.70}],
        "first-contentful-paint": ["warn", {"maxNumericValue": 3000}],
        "largest-contentful-paint": ["warn", {"maxNumericValue": 4000}],
        "total-blocking-time": ["warn", {"maxNumericValue": 500}],
        "cumulative-layout-shift": ["warn", {"maxNumericValue": 0.25}],
        "meta-description": ["warn", {"minScore": 1}],
        "color-contrast": ["warn", {"minScore": 0.9}]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
